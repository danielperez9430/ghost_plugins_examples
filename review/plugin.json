{
  "name": "review",
  "version": "1.0.0",
  "label": "Review Card",
  "description": "Product/app review card with score, pros/cons, and rating bars",
  "icon": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>",
  "cards": [
    {
      "name": "review",
      "label": "Review Card",
      "preprocess": "preprocess.js",
      "fields": [
        { "key": "score", "type": "number", "title": "Score (0-10)", "default": 0, "min": 0, "max": 10, "step": 0.1, "width": "half" },
        { "key": "scoreLabel", "type": "text", "title": "Score Label", "default": "NOTA", "width": "half" },
        { "key": "title", "type": "text", "title": "Title" },
        { "key": "subtitle", "type": "text", "title": "Subtitle" },
        { "key": "pros", "type": "textarea", "title": "Pros (one per line)" },
        { "key": "cons", "type": "textarea", "title": "Cons (one per line)" },
        { "key": "ratings", "type": "textarea", "title": "Ratings (Label=Score per line)" }
      ]
    }
  ]
}
